<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} | {{ site.name }} — Premium Taxi & Car Rental in Jodhpur</title>
  <meta name="description" content="{{ description or 'RCH Cabs — Premium taxi service and car rental in Jodhpur, Rajasthan. Trusted by travelers for over a decade. Luxury fleet, transparent pricing, 24/7 availability.' }}">
  
  <!-- Open Graph -->
  <meta property="og:title" content="{{ title }} | {{ site.name }}">
  <meta property="og:description" content="{{ description or 'Premium taxi service and car rental in Jodhpur, Rajasthan.' }}">
  <meta property="og:image" content="{{ site.url }}/assets/images/rajasthan-2000x1333.jpg">
  <meta property="og:url" content="{{ site.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.name }}">
  
  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ title }} | {{ site.name }}">
  <meta name="twitter:description" content="{{ description or 'Premium taxi service and car rental in Jodhpur, Rajasthan.' }}">
  <meta name="twitter:image" content="{{ site.url }}/assets/images/rajasthan-2000x1333.jpg">
  
  <!-- Favicon -->
  <link rel="shortcut icon" href="/assets/images/circle-logo.png" type="image/x-icon">
  
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,500&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  
  <!-- Styles -->
  <link rel="stylesheet" href="/css/style.css">
  
  {% if canonical %}
  <link rel="canonical" href="{{ canonical }}">
  {% endif %}

  {% if schema %}
  <script type="application/ld+json">{{ schema | safe }}</script>
  {% endif %}

  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.gaId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.gaId }}');
  </script>
</head>
<body>
  {% include "partials/nav.njk" %}
  
  <main>
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}

  <script src="/js/main.js"></script>
</body>
</html>
